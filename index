<!DOCTYPE html>

<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CH Logo SVG Files</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow:wght@200;300;400&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #EDEBE5; font-family: 'Barlow', sans-serif; font-weight: 300; color: #181614; padding: 40px 24px; }

h1 { font-size: 11px; letter-spacing: 0.5em; text-transform: uppercase; color: #8A857E; margin-bottom: 40px; }

.section-label {
font-size: 9px; letter-spacing: 0.4em; text-transform: uppercase;
color: #A09890; margin: 40px 0 16px; border-top: 1px solid #D4D0C8; padding-top: 20px;
}

.grid {
display: grid;
grid-template-columns: repeat(3, 1fr);
gap: 2px;
background: #D4D0C8;
}

.card {
background: #F5F1EB;
display: flex; flex-direction: column; align-items: center;
padding: 36px 20px 24px;
position: relative;
}
.card.dark { background: #181614; }
.card.trans {
background: repeating-conic-gradient(#D8D4CC 0% 25%, #EDEBE5 0% 50%) 0 0 / 16px 16px;
}

.card svg { width: 100px; height: 100px; }

.card-name {
margin-top: 16px; font-size: 8px; letter-spacing: 0.3em;
text-transform: uppercase; color: #8A857E; text-align: center;
}
.dark .card-name { color: #3A3632; }
.trans .card-name { color: #6A6560; }

.download-btn {
margin-top: 10px;
background: none; border: 1px solid #C8C4BC;
padding: 5px 12px; font-size: 8px; letter-spacing: 0.3em;
text-transform: uppercase; color: #8A857E; cursor: pointer;
font-family: ‘Barlow’, sans-serif; font-weight: 300;
transition: all 0.2s;
}
.download-btn:hover { background: #181614; color: #F5F1EB; border-color: #181614; }
.dark .download-btn { border-color: #2A2622; color: #3A3632; }
.dark .download-btn:hover { background: #F5F1EB; color: #181614; border-color: #F5F1EB; }
.trans .download-btn { background: rgba(245,241,235,0.85); }

.note {
margin-top: 40px; font-size: 10px; line-height: 2;
color: #8A857E; letter-spacing: 0.05em; border-top: 1px solid #D4D0C8; padding-top: 20px;
}

@media (max-width: 600px) { .grid { grid-template-columns: 1fr 1fr; } }
</style>

</head>
<body>

<h1>CH — SVG Logo Files</h1>

<!-- BAUHAUS -->

<div class="section-label">01 · Bauhaus Geometric</div>
<div class="grid">

  <div class="card">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200">
      <rect width="200" height="200" fill="#F5F1EB"/>
      <path d="M110 50 A60 60 0 0 0 110 150" stroke="#181614" stroke-width="10" fill="none" stroke-linecap="square"/>
      <line x1="110" y1="50" x2="110" y2="150" stroke="#181614" stroke-width="10" stroke-linecap="square"/>
      <line x1="148" y1="50" x2="148" y2="150" stroke="#181614" stroke-width="10" stroke-linecap="square"/>
      <line x1="110" y1="100" x2="148" y2="100" stroke="#181614" stroke-width="10" stroke-linecap="square"/>
    </svg>
    <div class="card-name">Ivory BG</div>
    <button class="download-btn" onclick="downloadSVG('bauhaus-ivory')">↓ SVG</button>
  </div>

  <div class="card dark">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200">
      <rect width="200" height="200" fill="#181614"/>
      <path d="M110 50 A60 60 0 0 0 110 150" stroke="#F5F1EB" stroke-width="10" fill="none" stroke-linecap="square"/>
      <line x1="110" y1="50" x2="110" y2="150" stroke="#F5F1EB" stroke-width="10" stroke-linecap="square"/>
      <line x1="148" y1="50" x2="148" y2="150" stroke="#F5F1EB" stroke-width="10" stroke-linecap="square"/>
      <line x1="110" y1="100" x2="148" y2="100" stroke="#F5F1EB" stroke-width="10" stroke-linecap="square"/>
    </svg>
    <div class="card-name">Ink BG</div>
    <button class="download-btn" onclick="downloadSVG('bauhaus-ink')">↓ SVG</button>
  </div>

  <div class="card trans">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200">
      <path d="M110 50 A60 60 0 0 0 110 150" stroke="#181614" stroke-width="10" fill="none" stroke-linecap="square"/>
      <line x1="110" y1="50" x2="110" y2="150" stroke="#181614" stroke-width="10" stroke-linecap="square"/>
      <line x1="148" y1="50" x2="148" y2="150" stroke="#181614" stroke-width="10" stroke-linecap="square"/>
      <line x1="110" y1="100" x2="148" y2="100" stroke="#181614" stroke-width="10" stroke-linecap="square"/>
    </svg>
    <div class="card-name">透明背景</div>
    <button class="download-btn" onclick="downloadSVG('bauhaus-transparent')">↓ SVG</button>
  </div>

</div>

<!-- OVERLAP -->

<div class="section-label">05 · Overlap Tension</div>
<div class="grid">

  <div class="card">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200">
      <rect width="200" height="200" fill="#F5F1EB"/>
      <circle cx="88" cy="100" r="52" stroke="#181614" stroke-width="6" fill="none" stroke-dasharray="244 82" stroke-dashoffset="41"/>
      <line x1="112" y1="42" x2="112" y2="158" stroke="#181614" stroke-width="13" stroke-linecap="square"/>
      <line x1="148" y1="42" x2="148" y2="158" stroke="#181614" stroke-width="13" stroke-linecap="square"/>
      <line x1="112" y1="100" x2="148" y2="100" stroke="#181614" stroke-width="13" stroke-linecap="square"/>
      <line x1="112" y1="42" x2="112" y2="158" stroke="#F5F1EB" stroke-width="4" stroke-linecap="square"/>
    </svg>
    <div class="card-name">Ivory BG</div>
    <button class="download-btn" onclick="downloadSVG('overlap-ivory')">↓ SVG</button>
  </div>

  <div class="card dark">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200">
      <rect width="200" height="200" fill="#181614"/>
      <circle cx="88" cy="100" r="52" stroke="#F5F1EB" stroke-width="6" fill="none" stroke-dasharray="244 82" stroke-dashoffset="41"/>
      <line x1="112" y1="42" x2="112" y2="158" stroke="#F5F1EB" stroke-width="13" stroke-linecap="square"/>
      <line x1="148" y1="42" x2="148" y2="158" stroke="#F5F1EB" stroke-width="13" stroke-linecap="square"/>
      <line x1="112" y1="100" x2="148" y2="100" stroke="#F5F1EB" stroke-width="13" stroke-linecap="square"/>
      <line x1="112" y1="42" x2="112" y2="158" stroke="#181614" stroke-width="4" stroke-linecap="square"/>
    </svg>
    <div class="card-name">Ink BG</div>
    <button class="download-btn" onclick="downloadSVG('overlap-ink')">↓ SVG</button>
  </div>

  <div class="card trans">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200">
      <circle cx="88" cy="100" r="52" stroke="#181614" stroke-width="6" fill="none" stroke-dasharray="244 82" stroke-dashoffset="41"/>
      <line x1="112" y1="42" x2="112" y2="158" stroke="#181614" stroke-width="13" stroke-linecap="square"/>
      <line x1="148" y1="42" x2="148" y2="158" stroke="#181614" stroke-width="13" stroke-linecap="square"/>
      <line x1="112" y1="100" x2="148" y2="100" stroke="#181614" stroke-width="13" stroke-linecap="square"/>
    </svg>
    <div class="card-name">透明背景</div>
    <button class="download-btn" onclick="downloadSVG('overlap-transparent')">↓ SVG</button>
  </div>

</div>

<div class="note">
  各檔案皆為 200×200px SVG，可無限縮放不失真。<br>
  透明背景版適合貼入 Mockup 場景、Photoshop 智慧型物件，或 Adobe Firefly 生成式填充。<br>
  深色版與亮色版可直接用於社群媒體貼文、名片設計等應用。
</div>

<script>
const svgData = {
  'bauhaus-ivory': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="200" height="200"><rect width="200" height="200" fill="#F5F1EB"/><path d="M110 50 A60 60 0 0 0 110 150" stroke="#181614" stroke-width="10" fill="none" stroke-linecap="square"/><line x1="110" y1="50" x2="110" y2="150" stroke="#181614" stroke-width="10" stroke-linecap="square"/><line x1="148" y1="50" x2="148" y2="150" stroke="#181614" stroke-width="10" stroke-linecap="square"/><line x1="110" y1="100" x2="148" y2="100" stroke="#181614" stroke-width="10" stroke-linecap="square"/></svg>`,
  'bauhaus-ink': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="200" height="200"><rect width="200" height="200" fill="#181614"/><path d="M110 50 A60 60 0 0 0 110 150" stroke="#F5F1EB" stroke-width="10" fill="none" stroke-linecap="square"/><line x1="110" y1="50" x2="110" y2="150" stroke="#F5F1EB" stroke-width="10" stroke-linecap="square"/><line x1="148" y1="50" x2="148" y2="150" stroke="#F5F1EB" stroke-width="10" stroke-linecap="square"/><line x1="110" y1="100" x2="148" y2="100" stroke="#F5F1EB" stroke-width="10" stroke-linecap="square"/></svg>`,
  'bauhaus-transparent': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="200" height="200"><path d="M110 50 A60 60 0 0 0 110 150" stroke="#181614" stroke-width="10" fill="none" stroke-linecap="square"/><line x1="110" y1="50" x2="110" y2="150" stroke="#181614" stroke-width="10" stroke-linecap="square"/><line x1="148" y1="50" x2="148" y2="150" stroke="#181614" stroke-width="10" stroke-linecap="square"/><line x1="110" y1="100" x2="148" y2="100" stroke="#181614" stroke-width="10" stroke-linecap="square"/></svg>`,
  'overlap-ivory': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="200" height="200"><rect width="200" height="200" fill="#F5F1EB"/><circle cx="88" cy="100" r="52" stroke="#181614" stroke-width="6" fill="none" stroke-dasharray="244 82" stroke-dashoffset="41"/><line x1="112" y1="42" x2="112" y2="158" stroke="#181614" stroke-width="13" stroke-linecap="square"/><line x1="148" y1="42" x2="148" y2="158" stroke="#181614" stroke-width="13" stroke-linecap="square"/><line x1="112" y1="100" x2="148" y2="100" stroke="#181614" stroke-width="13" stroke-linecap="square"/><line x1="112" y1="42" x2="112" y2="158" stroke="#F5F1EB" stroke-width="4" stroke-linecap="square"/></svg>`,
  'overlap-ink': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="200" height="200"><rect width="200" height="200" fill="#181614"/><circle cx="88" cy="100" r="52" stroke="#F5F1EB" stroke-width="6" fill="none" stroke-dasharray="244 82" stroke-dashoffset="41"/><line x1="112" y1="42" x2="112" y2="158" stroke="#F5F1EB" stroke-width="13" stroke-linecap="square"/><line x1="148" y1="42" x2="148" y2="158" stroke="#F5F1EB" stroke-width="13" stroke-linecap="square"/><line x1="112" y1="100" x2="148" y2="100" stroke="#F5F1EB" stroke-width="13" stroke-linecap="square"/><line x1="112" y1="42" x2="112" y2="158" stroke="#181614" stroke-width="4" stroke-linecap="square"/></svg>`,
  'overlap-transparent': `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 200 200" width="200" height="200"><circle cx="88" cy="100" r="52" stroke="#181614" stroke-width="6" fill="none" stroke-dasharray="244 82" stroke-dashoffset="41"/><line x1="112" y1="42" x2="112" y2="158" stroke="#181614" stroke-width="13" stroke-linecap="square"/><line x1="148" y1="42" x2="148" y2="158" stroke="#181614" stroke-width="13" stroke-linecap="square"/><line x1="112" y1="100" x2="148" y2="100" stroke="#181614" stroke-width="13" stroke-linecap="square"/></svg>`
};

function downloadSVG(key) {
  const blob = new Blob([svgData[key]], { type: 'image/svg+xml' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `ch-logo-${key}.svg`;
  a.click();
  URL.revokeObjectURL(url);
}
</script>

</body>
</html>
